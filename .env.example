# --- AWS Configuration ---
# The AWS profile configured via `aws configure --profile dev`
AWS_PROFILE=dev
# The AWS region where DSQL and DynamoDB are deployed
AWS_REGION=ap-northeast-1

# --- Database & Cache (Dynamically generated by Terraform in real .env) ---
# The URL/Endpoint for your Amazon Aurora DSQL Cluster
# Automatically populated by running: `make setup-env` or `make setup`
DSQL_ENDPOINT=your-dsql-cluster-identifier.dsql.ap-northeast-1.on.aws
DYNAMODB_TABLE_NAME=version-checker-eol-cache-dev

# --- Authentication (GitHub App) ---
# See walkthrough.md for instructions on how to obtain these
GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret

# --- General Application Settings ---
NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000
# FastAPI Backend URL used by Nuxt 3 frontend locally
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
